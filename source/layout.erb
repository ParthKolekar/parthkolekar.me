---

<!DOCTYPE html>
<html lang="en" itemscope itemtype="http://schema.org/Article">
<head>
<%= partial(:meta) %>
  <link rel="stylesheet" type="text/css" href="/stylesheets/main.css" />
  <link rel="stylesheet" type="text/css" href="/blog/stylesheets/highlights.css" />
  <link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/normalize/5.0.0/normalize.min.css" />
  <link rel="stylesheet" type="text/css" href="/blog/stylesheets/layout-breaker-hacks.css" />
  <script src="https://use.fontawesome.com/24ce601765.js"></script>
</head>
<body>
  <div id="page-wrapper" class="page-wrapper">
<%= partial(:navbars) %>
    <div id="content" class="page animated">
      <main id="main-content" class="text page animated content hidden">
        <div class="scroll-parent" id="container">
          <article class="scroll-child">
            <header class="scroll-child-child content-rotating">
<% if is_featured(current_page) %>
              <div style="display: flex; flex-direction: row;">
                <div style="flex-grow: 1"></div>
<%= partial(:featured) %>                
              </div>
<% end %>
              <h1 class="color-white" style="font-size: 3em"> <%= current_page.title %> </h1>
              <h2 class="color-lightgrey"><%= current_page.date.strftime('%B %e ') %><a href="/blog/<%= current_page.date.strftime('%Y') %>"><%= current_page.date.strftime('%Y') %></a></h2>
              <em class="color-lightgrey" style="font-size: 2em">
<% current_page.tags.sort.each do |tag| %>
                #<a href="<%= tag_path tag %>" rel="tag"><%= tag %></a>
<% end %>
              </em>
            </header>
            <hr style="width: 80%;" class="color-neon" />
            <div class="scroll-child-child content-rotating color-white" style="display: flex; flex-direction: row;">
              <div style="flex-grow: 1"></div>
              <div style="width: 90%;">
<%= yield %>
                <div style="height: 50px; width: 100%"></div>    
<%= partial(:socialmedia) %>
                <div style="height: 50px; width: 100%"></div>    
                <div itemprop="author" itemscope itemtype="http://schema.org/Person">
                  <div itemprop="name" class="color-white" style="font-size: 2em;text-align: right;"> Parth Kolekar </div>
                </div>
              </div>
              <div style="flex-grow: 1"></div>
            </div>
<% related(current_article).first(2).each do |article| %>
            <hr style="width: 80%;" class="color-neon" />
<%= partial(:articlemini, :locals => { :article => article, :mini_header => "Recommended Reading" }) %>
<% end %>
            <hr style="width: 80%;" class="color-neon" />
            <div class="scroll-child-child content-rotating" style="display: flex; justify-content: space-between; flex-direction: row">
<% if current_page.article_previous %>
              <a class="navbar" rel="prev" style="padding: 25px; border: 0;" href="<%= current_page.article_previous.url %>">&laquo; Prev - <%= current_page.article_previous.title %></a>  
<% else %>
              <div class="navbar" style="padding: 25px; border: 0; background-color: rgba(50,50,50,.65);">&laquo; Prev </div>  
<% end %>
<% if current_page.article_next %>
              <a class="navbar" rel="next" style="padding: 25px; border: 0;" href="<%= current_page.article_next.url %>">Next &raquo; - <%= current_page.article_next.title %> </a>  
<% else %>
              <div class="navbar" style="padding: 25px; border: 0; background-color: rgba(50,50,50,.65);">Next &raquo; </div>
<% end %>
            </div>
          </article>
        </div>
      </main>
    </div>
  </div>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.perfect-scrollbar/0.6.16/js/perfect-scrollbar.min.js"></script>
  <script type="text/javascript">
    var container = document.getElementById('container');
    Ps.initialize(container);
  </script>
  <script src='https://js.sentry-cdn.com/86cd5456d19942879f06530866c31798.min.js' crossorigin="anonymous"></script>
  <script type="text/javascript" src="/javascripts/main.js"></script>
</body>
</html>
