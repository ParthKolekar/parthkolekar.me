---
---

<!DOCTYPE html>
<html lang="en" itemscope itemtype="http://schema.org/Person">
<head>
<%= partial(:meta) %>
  <link rel="stylesheet" type="text/css" href="/stylesheets/main.css" />
  <link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/normalize/5.0.0/normalize.min.css" />
  <script src="https://use.fontawesome.com/24ce601765.js"></script>
</head>
<body>
  <div id="page-wrapper" class="page-wrapper">
    <nav id="navbars" class="animated navbars navbars-rotating">
      <a href="/#/home" id="home-button" data-page='home-content' class="navbar animated" style="text-decoration: none;"> Home </a>
      <a href="/#/contact" id="contact-button" data-page='contact-content' class="navbar animated" style="text-decoration: none;"> Contact </a>
      <a href='/blog/' id="blog-button" data-page='blog-content' class="navbar animated" style="text-decoration: none;"> Blog </a>
      <a href="/resume" id="resume-button" data-page='resume-content' class="navbar animated" style="text-decoration: none;"> R&eacute;sum&eacute; </a>
    </nav>
    <main id="content" class="page animated">
      <section id="home-content" class="text animated content">
        <div class="scroll-parent" id="container">
          <div class="scroll-child">
<%= partial(:bio) %>
            <hr style="width: 80%;" class="color-neon" />
<%= partial(:skills) %>
            <hr style="width: 80%;" class="color-neon" />
<%= partial(:environment) %>
          </div>
        </div>
      </section>
      <section id="contact-content" class="text animated hidden content">
        <div class="scroll-parent">
          <div class="scroll-child">
<%= partial(:contact) %>
          </div>
        </div>
      </section>
    </main>
  </div>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.perfect-scrollbar/0.6.16/js/perfect-scrollbar.min.js"></script>
  <script type="text/javascript">
    var container = document.getElementById('container');
    Ps.initialize(container);
  </script>
  <script src='https://js.sentry-cdn.com/86cd5456d19942879f06530866c31798.min.js' crossorigin="anonymous"></script>
  <script type="text/javascript" src="/javascripts/main.js"></script>
</body>
</html>
